import deportes.*
import atletas.*

describe "Grupo de test" {
  test "Victoria quiere ser Pareto,y su presupuesto es mayor a 500" {
    victoria.altura(150)
    victoria.cambiarDisciplina(judo)
    victoria.cambiarElemento(trajeJudo)
    victoria.cantEntrenadores(4)
    assert.that(victoria.presupuestoTotal()>500)
  }

  test " Victoria quiere ser Del Potro,y su presupuesto es mayor a 1000" {
    victoria.altura(210)
    victoria.cambiarDisciplina(tenis)
    victoria.cambiarElemento(raqueta)
    victoria.cantEntrenadores(2)
    assert.that(victoria.presupuestoTotal()>1000)
  }

  test "Victoria quiere jugar hockey, el palo de hockey le cuesta 40" {
    victoria.altura(210)
    victoria.cambiarDisciplina(hockey)
    victoria.cambiarElemento(paloHockey)
    victoria.cantEntrenadores(1)
    assert.equals(40, paloHockey.costoPara(victoria))
  }

  test "Victoria quiere hacer cualquier cosa, y puede" {
    victoria.altura(210)
    victoria.cambiarDisciplina(judo)
    victoria.cambiarElemento(raqueta)
    victoria.cantEntrenadores(2)
    assert.that(victoria.presupuestoTotal()>1000)
  }
}

  



